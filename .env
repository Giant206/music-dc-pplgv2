# PPLGBot - Environment Variables
# Copy file ini ke .env dan isi dengan kredensial Anda

# ============================================
# 🔐 BOT TOKEN (WAJIB)
# ============================================
TOKEN=

# ============================================
# 🗄️ MONGODB URI (WAJIB)
# ============================================
MONGODB_URI=

# ============================================
# 🎵 GENIUS LYRICS (OPSIONAL)
# ============================================
# Dapatkan token di https://genius.com/developers
GENIUS_TOKEN=

# ============================================
# 🐛 DEBUG MODE (OPSIONAL)
# ============================================
DEBUG=false

# ============================================
# 📝 CATATAN
# ============================================
# - TOKEN wajib diisi agar bot dapat login
# - GENIUS_TOKEN opsional untuk fitur lyrics
# - DEBUG=true untuk melihat log detail


